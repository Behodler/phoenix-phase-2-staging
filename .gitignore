# Throwaway scratchpad script. Committed once as an empty skeleton, then
# ignored so local scratch work is never tracked. NOTE: .gitignore alone does
# not stop commits to an already-tracked file; this is backed by
# `git update-index --skip-worktree script/interactions/Temp.s.sol` locally.
# Run that command after cloning to keep your scratch edits untracked.
script/interactions/Temp.s.sol